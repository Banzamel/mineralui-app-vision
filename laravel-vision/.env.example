APP_NAME=Vision
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

AUTH_GUARD=api

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Host = nazwa serwisu z docker-compose (mysql-vision). Na bare-metal zmień na 127.0.0.1.
DB_CONNECTION=mysql
DB_HOST=mysql-vision
DB_PORT=3306
DB_DATABASE=vision
DB_USERNAME=vision
DB_PASSWORD=vision_password

REDIS_CLIENT=predis
REDIS_HOST=redis-vision
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

FILESYSTEM_DISK=local

# Reverb — wewnątrz kontenera bindujemy się na 0.0.0.0, frontend woła po localhost:8080.
REVERB_APP_ID=vision
REVERB_APP_KEY=vision_reverb_key
REVERB_APP_SECRET=vision_reverb_secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

VISION_VERSION=1.0.0

# Nazwa klienta Passport (grant password) tworzonego przez laravel-init.sh.
# AuthorizationService::login() szuka klienta po tej nazwie.
PASSPORT_DESKTOP_CLIENT="Vision Web"

# Ustawiane przez /install/finalize — nie dotykaj ręcznie.
APP_INSTALLED=false
