# API backend
VITE_API_URL=/api
VITE_USE_MOCKS=false

# Reverb (broadcast)
VITE_REVERB_APP_KEY=vision-app-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Web Push (VAPID public key — paste the value generated by VAPID::createVapidKeys() on the backend).
VITE_VAPID_PUBLIC_KEY=
